    { id: 2, companyName: 'Eurobiz Corporation', buildingNumber: '171', buildingName: 'Plaza', floor: '', unitNumber: '', ownerId: 2, billType: 'Electricity', customerId: '10558686', consumerNumber: '44115635517101 U', accountNumber: '0.00', referenceNumber: '44115635517101 U', dueDate: '2025-12-16', billMonth: '2025-11', status: 'Pending', billAmount: 0, paidBy: 'Company', notes: '' },
