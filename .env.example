# Neon Database Configuration
# Get your connection string from Neon Console: https://console.neon.tech

# PostgreSQL connection string for Neon
# Format: postgresql://username:password@hostname/dbname?sslmode=require
DATABASE_URL="postgresql://username:password@hostname/dbname?sslmode=require"

# For Neon serverless driver (alternative)
# NEON_DB_HOST=your-hostname
# NEON_DB_DATABASE=your-database-name
# NEON_DB_USER=your-username
# NEON_DB_PASSWORD=your-password

# Application Configuration
NEXT_PUBLIC_APP_NAME="Grand City Dashboard"
NEXT_PUBLIC_APP_VERSION="2.0.0"

# Deployment Environment (development | production)
NODE_ENV="development"

# Optional: Custom API base URL (if using separate backend)
NEXT_PUBLIC_API_URL=""

# Vercel Environment Variables
# When deploying to Vercel, set these in the Vercel dashboard:
# Settings > Environment Variables > Add New
#
# Required variables:
# - DATABASE_URL (Copy from Neon console)
# - NODE_ENV (set to "production")
