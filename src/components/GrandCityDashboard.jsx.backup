import { 
  Building2, FileText, Bell, Plus, Edit2, Trash2, Download, Upload,
  AlertCircle, CheckCircle, Clock, Search, X, Phone, Mail, 
  MessageSquare, Wrench, TrendingUp, Users, Calendar, Filter,
  Home, Zap, Droplet, Flame, Wifi, DollarSign
} from 'lucide-react';

const GrandCityManagementComplete = () => {
  // Complete initial owners data
  const initialOwners = [
    { id: 1, name: "Brig Shahid", mobile: "0323 4194444", email: "shahid@grandcity.pk", buildings: ["170"], notes: "Owner of Building 170" },
    { id: 2, name: "Fareed Faridi", mobile: "+92 312 4225106", email: "fareed@grandcity.pk", buildings: ["171"], notes: "Owner of Building 171" },
    { id: 3, name: "Waseem Ijaz", mobile: "+92 301 4681313", email: "waseem@grandcity.pk", buildings: ["172"], notes: "Owner of Building 172" },
    { id: 4, name: "Grand City HQ", mobile: "+92 300 1234567", email: "hq@grandcity.pk", buildings: ["38", "129"], notes: "Additional Properties - Cantt View & 7 D" }
  ];

  // Complete pre-loaded bills data - ALL 28 bills
  const preloadedBills = [
    // Electricity - Eurobiz Corporation (Plaza Buildings)
